{
  "name": "beatsaber-overlay",
  "description": "Beat Saber stream overlay for OBS",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write 'src/**/*.{ts,css,html}'",
    "format:check": "prettier --check 'src/**/*.{ts,css,html}'",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@takazudo/mdx-formatter": "^0.4.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
